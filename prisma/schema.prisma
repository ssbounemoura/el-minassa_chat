generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MODÈLE USER (défini en premier)
// ============================================
model User {
  id                            String                    @id @default(cuid())
  name                          String
  email                         String                    @unique
  password                      String
  role                          String                    @default("AVOCAT")
  phone                         String?
  officeName                    String?
  avatar                        String?
  isActive                      Boolean                   @default(true)
  isEmailVerified               Boolean                   @default(false)
  emailVerificationToken        String?
  emailVerificationTokenExpiry  DateTime?
  wilayaId                      String?
  customWilaya                  String?
  createdAt                     DateTime                  @default(now())
  updatedAt                     DateTime                  @updatedAt
  
  // Relations
  wilaya                        Wilaya?                   @relation(fields: [wilayaId], references: [id])
  subscription                  Subscription?
  dossiers                      Dossier[]
  clients                       Client[]
  rendezVous                    RendezVous[]
  documents                     Document[]
  factures                      Facture[]
  notifications                 Notification[]
  sentMessages                  Message[]                 @relation("SentMessages")
  conversationParticipants      ConversationParticipant[]
  chatSessions                  ChatSession[]
  aiConversations               AiConversation[]
  
  // Relations NOTAIRE
  actesNotaries                 ActeNotarie[]             @relation("NotaireActes")
  registres                     RegistreNotariae[]        @relation("NotaireRegistres")
  aides                         AideNotaire[]             @relation("NotaireAides")
  templates                     TemplateActe[]            @relation("NotaireTemplates")

  @@map("users")
}

// ============================================
// MODÈLE WILAYA
// ============================================
model Wilaya {
  id    String @id @default(cuid())
  code  String @unique
  name  String
  users User[]

  @@map("wilayas")
}

// ============================================
// MODÈLES POUR LE CHAT
// ============================================
model Conversation {
  id           String                     @id @default(cuid())
  type         String                     // "private", "group", "profession"
  title        String?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  attachmentUrl  String?
  isRead         Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

// ============================================
// MODÈLE PLAN
// ============================================
model Plan {
  id           String         @id @default(cuid())
  name         String
  price        Float
  durationDays Int            @default(30)
  features     String
  maxDossiers  Int            @default(50)
  maxClients   Int            @default(100)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  subscriptions Subscription[]

  @@map("plans")
}

// ============================================
// MODÈLE SUBSCRIPTION
// ============================================
model Subscription {
  id         String     @id @default(cuid())
  userId     String     @unique
  user       User       @relation(fields: [userId], references: [id])
  planId     String
  plan       Plan       @relation(fields: [planId], references: [id])
  startDate  DateTime   @default(now())
  endDate    DateTime
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  paiements  Paiement[]

  @@map("subscriptions")
}

// ============================================
// MODÈLE CLIENT (CORRIGÉ - avec relation inverse)
// ============================================
model Client {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  fullName   String
  phone      String?
  email      String?
  address    String?
  nationalId String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  dossiers   Dossier[]
  actesNotaries ActeNotarie[]

  @@map("clients")
}

// ============================================
// MODÈLE DOSSIER
// ============================================
model Dossier {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  clientId    String?
  client      Client?     @relation(fields: [clientId], references: [id])
  title       String
  description String?
  caseType    String
  status      String      @default("EN_COURS")
  courtName   String?
  caseNumber  String?
  parties     String?
  notes       String?
  nextHearing DateTime?
  deadline    DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  documents   Document[]
  rendezVous  RendezVous[]

  @@map("dossiers")
}

// ============================================
// MODÈLE RENDEZ-VOUS
// ============================================
model RendezVous {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  dossierId   String?
  dossier     Dossier?  @relation(fields: [dossierId], references: [id])
  title       String
  description String?
  date        DateTime
  time        String?
  duration    Int       @default(30)
  location    String?
  isDone      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@map("rendez_vous")
}

// ============================================
// MODÈLE DOCUMENT
// ============================================
model Document {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  dossierId String?
  dossier   Dossier?  @relation(fields: [dossierId], references: [id])
  title     String
  category  String?
  fileUrl   String
  fileSize  Int?
  createdAt DateTime  @default(now())

  @@map("documents")
}

// ============================================
// MODÈLE FACTURE
// ============================================
model Facture {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  invoiceNumber  String    @unique
  client         String
  amount         Float
  description    String?
  status         String    @default("BROUILLON")
  dueDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  paiements      Paiement[]

  @@map("factures")
}

// ============================================
// MODÈLE PAIEMENT
// ============================================
model Paiement {
  id             String        @id @default(cuid())
  factureId      String?
  facture        Facture?      @relation(fields: [factureId], references: [id])
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  amount         Float
  method         String        @default("CIB")
  reference      String?
  createdAt      DateTime      @default(now())

  @@map("paiements")
}

// ============================================
// MODÈLE NOTIFICATION
// ============================================
model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String
  content     String
  isRead      Boolean   @default(false)
  type        String    @default("info")
  priority    String    @default("normal")
  link        String?
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@map("notifications")
}

// ============================================
// MODÈLE CHAT SESSION (visiteur)
// ============================================
model ChatSession {
  id        String   @id @default(cuid())
  visitorId String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  messages  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_sessions")
}

// ============================================
// MODÈLE AI CONVERSATION
// ============================================
model AiConversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String?
  messages  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_conversations")
}

// ============================================
// MODÈLE ACTE NOTARIÉ (pour NOTAIRE) - CORRIGÉ
// ============================================
model ActeNotarie {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation("NotaireActes", fields: [userId], references: [id])
  
  // Informations de base
  numeroActe        String      @unique
  typeActe          String      // "VENTE", "DONATION", "MARIAGE", "SUCCESSION", "HYPOTHEQUE", "BAIL", etc.
  dateActe          DateTime
  dateEnregistrement DateTime?
  
  // Client principal (champ parties String supprimé)
  clientPrincipal   String?
  clientId          String?
  client            Client?     @relation(fields: [clientId], references: [id])
  
  // Détails légaux
  description       String?
  montantTransaction Float?
  references        String?     // Numéros de références légales
  
  // Statut et traçabilité
  status            String      @default("EN_COURS")  // EN_COURS, SIGNE, ENREGISTRE, ARCHIVE
  dateSignature     DateTime?
  signatureDigitale String?     // Hash de signature
  nombrePages       Int?
  
  // Documents
  documentUrl       String?
  certificats       String?     // JSON array of certificate URLs
  
  // Registre et archivage
  numeroRegistre    String?
  lieuRegistre      String?
  controleLegalite  Boolean     @default(false)
  remarques         String?
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  // Relations
  registreNotariae  RegistreNotariae?
  parties           Partie[]      @relation("ActeParties")
  
  @@index([userId])
  @@index([numeroActe])
  @@index([status])
  @@map("actes_notaries")
}

// ============================================
// MODÈLE REGISTRE NOTARIAL (pour NOTAIRE)
// ============================================
model RegistreNotariae {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation("NotaireRegistres", fields: [userId], references: [id])
  acteId        String        @unique
  acte          ActeNotarie   @relation(fields: [acteId], references: [id], onDelete: Cascade)
  
  // Numérotation
  numeroRegistre String       @unique
  sousNumero    Int           @default(0)
  volume        Int?
  page          Int?
  
  // Dates légales
  dateEnregistrement DateTime
  dateExpedition    DateTime?
  
  // Statut légal
  statusLegal   String        @default("ENREGISTRE")  // ENREGISTRE, TRANSCRIT, RETIRE, ANNULE
  fraisRegistre Float?
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@index([numeroRegistre])
  @@index([userId])
  @@map("registre_notariae")
}

// ============================================
// MODÈLE PARTIE (Signataire) - pour NOTAIRE
// ============================================
model Partie {
  id            String      @id @default(cuid())
  acteId        String
  acte          ActeNotarie @relation("ActeParties", fields: [acteId], references: [id], onDelete: Cascade)
  
  // Informations
  nomComplet    String
  qualite       String      // VENDEUR, ACQUEREUR, DONOR, DONATAIRE, etc.
  nationalite   String?
  dateNaissance DateTime?
  numIdNationale String?
  
  // Adresse
  adresseComplete String?
  wilaya        String?
  commune       String?
  
  // Contact
  telephone     String?
  email         String?
  
  // Signature
  dateSig       DateTime?
  signatureDigi String?     // Empreinte digitale ou signature électronique
  temoins       String?     // JSON: noms des témoins
  
  createdAt     DateTime    @default(now())
  
  @@index([acteId])
  @@map("parties")
}

// ============================================
// MODÈLE AIDE NOTAIRE (pour NOTAIRE)
// ============================================
model AideNotaire {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation("NotaireAides", fields: [userId], references: [id])
  
  // Informations
  titre         String
  description   String
  contenu       String    // Markdown format
  typeActe      String?   // Type d'acte concerné
  categorie     String    // PROCEDURE, LEGAL, TARIF, MODELE, DELAI, EXCEPTION
  
  // Mise à jour
  dateValidation DateTime @default(now())
  dateModification DateTime @updatedAt
  
  createdAt     DateTime  @default(now())
  
  @@index([userId])
  @@index([categorie])
  @@map("aides_notaire")
}

// ============================================
// MODÈLE TEMPLATE DOCUMENT NOTAIRE
// ============================================
model TemplateActe {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation("NotaireTemplates", fields: [userId], references: [id])
  
  // Identifiant
  nom           String
  typeActe      String    // VENTE, DONATION, etc.
  description   String?
  
  // Contenu
  contenuTemplate String  // Markdown avec placeholders {{nomClient}}, etc.
  champs        String    // JSON: liste des champs
  
  // Statut
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([userId])
  @@map("template_actes")
}

// ============================================
// MODÈLE LEGAL TEXT
// ============================================
model LegalText {
  id            String   @id @default(cuid())
  category      String
  lawReference  String
  articleNumber String
  title         String
  content       String
  keywords      String
  createdAt     DateTime @default(now())

  @@map("legal_texts")
}