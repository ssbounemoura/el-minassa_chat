{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/summarize/layout,_N_T_/dashboard/summarize/page,_N_T_/dashboard/summarize"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/summarize/__PAGE__",
    "/dashboard/summarize",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}