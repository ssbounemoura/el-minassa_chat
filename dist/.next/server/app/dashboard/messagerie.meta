{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/messagerie/layout,_N_T_/dashboard/messagerie/page,_N_T_/dashboard/messagerie"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/messagerie/__PAGE__",
    "/dashboard/messagerie",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}