{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/rendez-vous/layout,_N_T_/dashboard/rendez-vous/page,_N_T_/dashboard/rendez-vous"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/rendez-vous/__PAGE__",
    "/dashboard/rendez-vous",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}