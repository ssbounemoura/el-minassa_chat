{
  "buildCommand": "prisma generate && next build",
  "devCommand": "next dev",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "regions": ["cdg1"],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/check-hearings",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/check-invoices",
      "schedule": "0 9 * * *"
    }
  ]
}